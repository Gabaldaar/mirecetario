rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de utilidad para mayor legibilidad
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRecipeOwner(recipeData) {
      return isAuthenticated() && recipeData.createdBy == request.auth.uid;
    }

    function isFavoriteOwner(favoriteData) {
      return isAuthenticated() && favoriteData.userId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "gab.aldazabal@gmail.com";
    }

    // Reglas para la colección de usuarios
    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if request.auth.uid == userId;
    }

    // Reglas para la colección maestra de recetas
    match /recipes/{recipeId} {
      allow read: if true; // Cualquiera puede leer recetas compartidas
      
      allow create: if isAuthenticated() 
        && request.resource.data.createdBy == request.auth.uid;
      
      allow update, delete: if isRecipeOwner(resource.data);
    }

    // Reglas para la colección de favoritos
    match /favorites/{favoriteId} {
      // Para crear, el userId del nuevo documento debe coincidir con el usuario autenticado
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
        
      // Para leer, modificar o borrar, el documento existente debe pertenecer al usuario autenticado
      allow read, update, delete: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
    }

    // Reglas para la colección de menús colaborativos/personales
    match /menus/{menuId} {
      allow read, write: if isAuthenticated() && request.auth.uid == menuId;
    }

    // Reglas para la colección de ingredientes maestros
    match /ingredients/{ingredientId} {
      allow read: if true; // Lectura pública para autocompletar
      allow create, update, delete: if isAuthenticated(); // Solo registrados modifican ingredientes
    }
  }
}
